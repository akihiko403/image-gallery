# Primary database connection for Render or any hosted PostgreSQL service
DATABASE_URL=postgresql://USERNAME:PASSWORD@HOSTNAME:5432/DATABASE_NAME

# Optional fallback variables for local PostgreSQL setup
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=image_gallery
DB_USER=postgres
DB_PASS=your_postgres_password
DB_SSLMODE=

# File storage root
STORAGE_ROOT=/var/www/html/storage
STORAGE_URL_ROOT=storage
